{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "adapters/cursor/adapter.sh session-start", "timeout": 10 }
    ],
    "preToolUse": [
      { "command": "adapters/cursor/adapter.sh pre-tool", "timeout": 5, "failClosed": false }
    ],
    "postToolUse": [
      { "command": "adapters/cursor/adapter.sh post-tool", "timeout": 5 }
    ],
    "postToolUseFailure": [
      { "command": "adapters/cursor/adapter.sh error", "timeout": 5 }
    ],
    "sessionEnd": [
      { "command": "adapters/cursor/adapter.sh session-end", "timeout": 15 }
    ]
  }
}
