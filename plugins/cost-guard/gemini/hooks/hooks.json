{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "\"${extensionPath}/hooks/entry.sh\" session-start", "timeout": 10000 }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "\"${extensionPath}/hooks/entry.sh\" pre-tool", "timeout": 10000 }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "\"${extensionPath}/hooks/entry.sh\" post-tool", "timeout": 10000 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "\"${extensionPath}/hooks/entry.sh\" session-end", "timeout": 15000 }
        ]
      }
    ]
  }
}
